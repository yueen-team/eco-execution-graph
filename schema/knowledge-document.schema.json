{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eco-execution-graph/knowledge-document.v1",
  "title": "KnowledgeDocumentV1",
  "description": "知识治理中层的文档级 metadata-only 注册对象。不得保存 RAG Content、法规全文、技术规范全文或企业私有证据。",
  "type": "object",
  "required": [
    "doc_id",
    "doc_type",
    "title",
    "canonical_title",
    "rag_doc_ref",
    "content_hash",
    "metadata_hash",
    "effective_status",
    "supersedes",
    "superseded_by",
    "dedupe_group_id",
    "aliases",
    "source_refs",
    "review_status",
    "trace"
  ],
  "properties": {
    "doc_id": { "type": "string", "minLength": 3 },
    "doc_type": {
      "enum": ["law", "technical_standard", "policy_doc", "guideline", "manual", "unknown"]
    },
    "title": { "type": "string", "minLength": 1 },
    "canonical_title": { "type": "string", "minLength": 1 },
    "standard_no": { "type": ["string", "null"] },
    "rag_doc_ref": { "type": "string", "minLength": 1 },
    "rag_knowledge_base_id_suffix": { "type": ["string", "null"] },
    "content_hash": { "type": "string", "minLength": 8 },
    "metadata_hash": { "type": "string", "minLength": 8 },
    "effective_status": {
      "enum": ["effective", "draft", "deprecated", "superseded", "unknown"]
    },
    "effective_date": { "type": ["string", "null"] },
    "abolished_date": { "type": ["string", "null"] },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "array", "items": { "type": "string" } },
    "dedupe_group_id": { "type": "string", "minLength": 3 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "rag_doc_ref", "citation_locator", "locator_level", "source_hash"],
        "properties": {
          "node_id": { "type": "string" },
          "node_type": { "type": "string" },
          "rag_doc_ref": { "type": "string" },
          "citation_locator": { "type": "string" },
          "locator_level": { "type": "string" },
          "source_hash": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "review_status": { "enum": ["candidate", "human_reviewed", "approved", "rejected"] },
    "trace": {
      "type": "object",
      "required": ["source_report", "node_ids", "rag_doc_refs"],
      "properties": {
        "source_report": { "type": "string" },
        "node_ids": { "type": "array", "items": { "type": "string" } },
        "rag_doc_refs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "propertyNames": {
    "not": {
      "enum": ["Content", "content", "raw_text", "full_text", "original_text", "enterprise_name", "gps", "photo_path", "raw_report"]
    }
  },
  "additionalProperties": false
}
