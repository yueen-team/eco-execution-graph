{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eco-execution-graph/card.v1",
  "title": "FieldExecutionCardV1",
  "description": "《法条↔现场执行卡》。卡片是图的切片渲染,不是独立数据:所有内容字段必须带图引用,渲染时校验一致性(ARCHITECTURE §2.4)。",
  "type": "object",
  "required": ["card_id", "law_article_ref", "field_manifestations", "render_views", "review_status"],
  "properties": {
    "card_id": { "type": "string", "pattern": "^card:[a-z0-9-]+:[a-z0-9-]+$" },
    "title": { "type": "string" },
    "dimension": { "type": "string", "description": "本期固定:危废管理" },
    "law_article_ref": {
      "type": "object",
      "required": ["node_id"],
      "properties": {
        "node_id": { "type": "string" },
        "lineage_note": { "type": "string", "description": "法典沿革提示(如'法典生效后对应第 X 条')" }
      }
    },
    "field_manifestations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["issue_type_ref", "description"],
        "properties": {
          "issue_type_ref": { "type": "string" },
          "description": { "type": "string", "description": "这条违法在现场长什么样" },
          "frequency_signal": { "type": "string", "description": "聚合层统计引用(tier=aggregate),如'近 12 月 N 家企业出现'" }
        }
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string" }, "summary": { "type": "string" } } },
      "description": "向后兼容字段。新卡优先拆为 evidence_categories / evidence_field_requirements / evidence_private_refs / internal_capability_placeholders。"
    },
    "evidence_categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "label"],
        "properties": {
          "ref": { "type": "string" },
          "label": { "type": "string" },
          "tier": { "enum": ["shared", "private", "aggregate"] }
        }
      },
      "description": "证据类别,可进入 shared 版执行卡,如现场照片/台账记录/标签照片/转移联单。"
    },
    "evidence_field_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "summary", "share_level"],
        "properties": {
          "ref": { "type": "string" },
          "summary": { "type": "string" },
          "share_level": { "enum": ["shared_concept", "partial", "private"] }
        }
      },
      "description": "证据字段要求。shared 版只能输出概念级或部分字段,不得输出判断标准与真实样例。"
    },
    "evidence_private_refs": {
      "type": "array",
      "items": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string" }, "kind": { "enum": ["judgment_standard", "field_example", "audit_note"] } } },
      "description": "证据判断标准、真实样例、审核笔记等 private 引用,只允许 internal_full 视图使用。"
    },
    "internal_capability_placeholders": {
      "type": "array",
      "items": { "type": "object", "required": ["kind", "summary"], "properties": { "kind": { "type": "string" }, "summary": { "type": "string" }, "count": { "type": "integer", "minimum": 0 } } },
      "description": "shared 版执行卡对内部能力的数量占位,不得含 private ref 或明细内容。"
    },
    "rectifications": {
      "type": "array",
      "items": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string" }, "summary": { "type": "string" }, "pass_rate": { "type": "string" } } },
      "description": "tier=private,只在内部全量视图渲染"
    },
    "report_expressions": {
      "type": "array",
      "items": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string" } } },
      "description": "tier=private,只在内部全量视图渲染"
    },
    "pitfalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "text", "pitfall_type"],
        "properties": {
          "ref": { "type": "string" },
          "text": { "type": "string" },
          "pitfall_type": { "enum": ["pitfall_class", "pitfall_pattern_stat", "pitfall_instance"] },
          "tier": { "enum": ["shared", "private", "aggregate"] }
        }
      },
      "description": "踩雷点拆三层:class 可共有,pattern_stat 聚合输出,instance 私有。"
    },
    "legal_basis_status": {
      "enum": ["official_confirmed", "internal_reviewed", "candidate", "disputed", "no_legal_basis"],
      "description": "执行卡对外表达强度控制:依据/参考/内部提示/人工审核/管理建议。"
    },
    "related_obligations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "执行卡切片关联的 law_obligation 引用。"
    },
    "evidence_summary": { "type": "string" },
    "rectification_summary": { "type": "string" },
    "report_expression_summary": { "type": "string" },
    "graph_slice_refs": {
      "type": "object",
      "properties": {
        "nodes": { "type": "array", "items": { "type": "string" } },
        "edges": { "type": "array", "items": { "type": "string" } }
      },
      "description": "渲染该执行卡所依赖的图节点与边引用。"
    },
    "export_policy": {
      "type": "object",
      "properties": {
        "tier": { "enum": ["shared", "private", "aggregate"] },
        "export_allowed": { "type": "boolean" },
        "redaction": { "type": "string" }
      }
    },
    "quality_score": {
      "type": "object",
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "last_verified_at": { "type": "string" },
        "staleness_risk": { "enum": ["low", "medium", "high"] }
      }
    },
    "render_views": {
      "type": "object",
      "required": ["internal_full", "shared_export"],
      "properties": {
        "internal_full": { "type": "boolean" },
        "shared_export": {
          "type": "boolean",
          "description": "共有视图:private 栏位渲染为'已建立标准(N 条)'占位,不输出内容(ADR-0008)"
        }
      }
    },
    "review_status": { "enum": ["CANDIDATE", "HUMAN_REVIEWED", "APPROVED_BASELINE", "DEPRECATED"] }
  },
  "additionalProperties": false
}
