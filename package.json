{
  "name": "eco-execution-graph",
  "version": "0.1.0",
  "private": true,
  "description": "环保现场执行图谱:法律法规 × 技术规范 × 现场排查经验的关联图谱",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "prepare": "husky",
    "main:ship": "node scripts/git-workflow/main-ship.mjs",
    "graph:build": "python pipeline/build_graph.py",
    "graph:export:shared": "python pipeline/export.py --tier shared",
    "gap:report": "python pipeline/gap_report.py",
    "graph:quality": "python pipeline/quality_score.py",
    "monthly:compare": "python pipeline/monthly_report_compare.py",
    "regulatory:check": "python pipeline/regulatory_consistency_check.py",
    "pitfall:map": "python pipeline/pitfall_map.py",
    "ecocheck:aggregate": "python pipeline/ecocheck_aggregation.py",
    "api:test": "pnpm --dir graph-api test",
    "api:check": "pnpm --dir graph-api check",
    "api:smoke:intake": "pnpm --dir graph-api smoke:intake",
    "delivery:report": "python pipeline/final_delivery.py",
    "tencent:probe": "python pipeline/tencent_lke_probe.py all",
    "tencent:probe:embedding": "python pipeline/tencent_lke_probe.py embedding",
    "tencent:probe:tokenhub": "python pipeline/tencent_lke_probe.py tokenhub-chat",
    "tencent:probe:rag-retrieve": "python pipeline/tencent_lke_probe.py rag-retrieve",
    "upstream:lock": "python pipeline/upstream_lock.py",
    "upstream:inventory": "python pipeline/upstream_inventory.py",
    "upstream:import:eco-kb": "python pipeline/import_eco_kb.py",
    "upstream:visibility": "python pipeline/upstream_visibility.py",
    "upstream:contracts:spl": "python pipeline/import_spl_contracts.py",
    "upstream:compat": "python pipeline/contract_compatibility.py",
    "ontology:validate:report-only": "python pipeline/report_only_contract_validation.py",
    "ontology:validate:blocking": "python pipeline/report_only_contract_validation.py --mode blocking",
    "graph:schema:blocking": "python pipeline/graph_schema_gate.py",
    "rag:resolve": "python pipeline/rag_resolve.py",
    "rag:real:gate": "python pipeline/rag_real_smoke_gate.py",
    "external:verify": "python pipeline/external_verification_lane.py",
    "rag:contract": "python pipeline/rag_contract_test.py",
    "knowledge:governance": "python pipeline/knowledge_governance.py all",
    "knowledge:registry": "python pipeline/knowledge_governance.py build-registry",
    "knowledge:candidates": "python pipeline/knowledge_governance.py generate-candidates",
    "knowledge:publish": "python pipeline/knowledge_governance.py publish-bundles",
    "knowledge:check": "python pipeline/knowledge_governance.py all --check",
    "graph:build:full": "python pipeline/build_full_graph.py",
    "cards:generate:full": "python pipeline/card_generate.py --scope full",
    "graph:export:full:internal": "python pipeline/export.py --scope full --tier internal",
    "graph:export:full:shared": "python pipeline/export.py --scope full --tier shared",
    "leak:full": "python pipeline/validate_no_private_leak.py --scope full",
    "regulatory:check:full": "python pipeline/regulatory_consistency_check.py --scope full",
    "gap:report:full": "python pipeline/gap_report.py --scope full",
    "pitfall:map:full": "python pipeline/pitfall_map.py --scope full",
    "monthly:compare:full": "python pipeline/monthly_report_compare.py --scope full",
    "lineage:check": "python pipeline/import_lineage.py",
    "demo:pack": "python pipeline/demo_pack.py",
    "delivery:p2p3": "python pipeline/final_delivery_p2p3.py",
    "ui:dev": "pnpm --dir graph-ui dev",
    "ui:build": "pnpm --dir graph-ui build",
    "bdd:export": "gherkin-v39 --predictable-ids \"specs/features/*.feature\" > bdd/behavior-contracts.ndjson",
    "skills:index": "echo skills-index: not applicable in this project",
    "verify:check": "pwsh -ExecutionPolicy Bypass -File verify/verify.ps1 check",
    "verify:leak": "pwsh -ExecutionPolicy Bypass -File verify/verify.ps1 leak",
    "verify:all": "pwsh -ExecutionPolicy Bypass -File verify/verify.ps1 all",
    "verify:external": "pwsh -ExecutionPolicy Bypass -File verify/verify.ps1 external",
    "verify:rag:real": "pwsh -ExecutionPolicy Bypass -File verify/verify.ps1 external"
  },
  "devDependencies": {
    "@coco830/gherkin-v39-cli": "file:..\\gherkin-v39-cli",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  }
}
