# 腾讯云知识引擎原子能力 + RAG(法规全文检索)— 只放占位符,真实密钥永不入库
TENCENT_LKE_SECRET_ID=your-secret-id-here
TENCENT_LKE_SECRET_KEY=your-secret-key-here
TENCENT_LKE_APP_ID=your-app-id-here
TENCENT_LKE_REGION=ap-guangzhou
TENCENT_LKE_KNOWLEDGE_BASE_IDS=2036306946025328640,2012806427613073408
TENCENT_LKEAP_RAG_API_KEY=your-lkeap-rag-suite-api-key-here

# 腾讯云 TokenHub DeepSeek OpenAI 兼容接口
TENCENT_TOKENHUB_API_KEY=your-tokenhub-deepseek-api-key-here
TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_TOKENHUB_DEEPSEEK_MODEL=deepseek-v4-flash-202605

# 腾讯云智能体开发平台 RAG 应用调用(推荐知识库检索路径)
# 在智能体应用发布后,从「调用信息/API 管理」复制 AppKey;不要提交真实值。
TENCENT_ADP_BOT_APP_KEY=your-published-app-key-here
TENCENT_ADP_VISITOR_BIZ_ID=eco-execution-graph-local-dev

# EcoCheck outbox 事件源(P1 先用导出文件,后接服务)
ECOCHECK_OUTBOX_EXPORT_PATH=E:\path\to\outbox-export

# graph Web 内部审核台 API(CloudBase 云托管)
ECO_GRAPH_STAGING_PATH=E:\eco-execution-graph\data\private-staging\field-events.jsonl
ECO_GRAPH_API_TOKEN=replace-with-cloudbase-secret
ECO_GRAPH_ENV=development
ECO_GRAPH_DEPLOY_TARGET=local
ECO_GRAPH_MAX_BODY_BYTES=1048576

# 企业微信扫码登录(内部/小范围;不开手机号或邮箱注册)
# 企业微信管理台「自建应用」获取;redirect_uri 域名必须配为应用可信域名。
ECO_GRAPH_WECOM_CORP_ID=ww-your-corp-id
ECO_GRAPH_WECOM_AGENT_ID=1000002
ECO_GRAPH_WECOM_CORP_SECRET=your-agent-secret
ECO_GRAPH_WECOM_REDIRECT_URI=https://your-domain/auth/wecom/callback
# 逗号分隔的企业微信 userid 白名单;留空 = 放行全企业成员
ECO_GRAPH_WECOM_ALLOWED_USERS=
# 会话签名密钥,32+ 随机字符
ECO_GRAPH_SESSION_SECRET=replace-with-long-random-secret
